# Copier en config/.env si besoin. Les sources sans cle fonctionnent sans ce fichier.

# Adzuna: couvre notamment fr, gb, de, at, pl, mais pas ie/be/ch/sg.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# France Travail Offres d'emploi v2.
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Jooble Jobs API.
JOOBLE_API_KEY=

# JobSpy API local, par exemple rainmanjam/jobspy-api expose /api/v1/search_jobs.
JOBSPY_API_URL=http://127.0.0.1:8000
JOBSPY_API_KEY=

# Sources volontairement hors routine aujourd'hui:
# - SerpAPI: quota trop faible pour un run fiable.
# - VDAB: acces public/self-service exploitable non disponible ici.
# Garder ces variables seulement pour test ponctuel explicite.
SERPAPI_KEY=
VDAB_API_KEY=
VDAB_SEARCH_URL=

# Judge LLM optionnel sur le top N. Compatible OpenAI Responses API.
JOBRADAR_LLM_BASE_URL=https://codex.raphcvr.me/v1
JOBRADAR_LLM_API_KEY=
JOBRADAR_LLM_MODEL=gpt-5.4-mini
JOBRADAR_LLM_REASONING_EFFORT=high
JOBRADAR_LLM_TIMEOUT_SECONDS=360
